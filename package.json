{
  "name": "librarian",
  "version": "0.1.0",
  "description": "Personal book catalog application for macOS",
  "main": "electron/main.js",
  "private": true,
  "scripts": {
    "start": "concurrently \"npm run server\" \"npm run electron:dev\"",
    "react:start": "vite",
    "react:build": "vite build",
    "electron:dev": "wait-on http://localhost:5173 && electron .",
    "electron:build": "electron-builder",
    "server": "nodemon server/index.js",
    "server:prod": "node server/index.js",
    "build": "npm run react:build && npm run electron:build",
    "test": "jest --passWithNoTests",
    "lint": "eslint src server --ext .js,.jsx",
    "package:mac": "electron-builder --mac",
    "package:win": "electron-builder --win",
    "package:linux": "electron-builder --linux"
  },
  "keywords": [
    "electron",
    "react",
    "book-catalog",
    "pdf",
    "library"
  ],
  "author": "Bibliotheka Dev",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.13.6",
    "better-sqlite3": "^12.6.2",
    "canvas": "^3.2.1",
    "chokidar": "^5.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "electron": "^40.6.1",
    "express": "^5.2.1",
    "franc": "^6.2.0",
    "lodash.debounce": "^4.0.8",
    "minisearch": "^7.2.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "pdf-to-png-converter": "^3.14.0",
    "pdf2pic": "^3.2.0",
    "pdfjs-dist": "^5.5.207",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19",
    "tesseract.js": "^7.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "electron-builder": "^26.8.1",
    "electron-reload": "^2.0.0-alpha.1",
    "jest": "^30.2.0",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.6",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  }
}
